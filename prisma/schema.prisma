generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model CustomerProfile {
  id                  String   @id @default(uuid())
  shopId              String?
  phoneE164           String?
  fullName            String?
  firstName           String?
  lastName            String?
  email               String?
  addressLine1        String?
  addressLine2        String?
  city                String?
  stateProvince       String?
  postalCode          String?
  countryRegion       String?
  shopifyCustomerId   String?
  phoneVerifiedAt     DateTime?
  profileCompletedAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  shop                Shop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  sessions            AuthSession[]
  otpChallenges       OTPChallenge[]
  orderActionRequests OrderActionRequest[]
 megaskaOrders       MegaskaOrder[]
  walletAccounts      WalletAccount[]
  walletTransactions  WalletTransaction[]
  walletReservations  WalletReservation[]
  gstDocuments        GstDocument[]
  gstParties          GstParty[]
  refundRequests      RefundRequest[]
  codAdvanceIntents   CodAdvanceIntent[]
  recoveryTokens      CheckoutRecoveryToken[]

  @@unique([shopId, shopifyCustomerId])
  @@index([shopId])
  @@index([shopId, phoneE164])
  @@index([shopId, email])
}
model Shop {
  id                    String   @id @default(uuid())
  shopDomain            String   @unique
  accessToken           String?
  storefrontAccessToken String?
  scopes                String?
  isActive              Boolean  @default(true)
  installedAt           DateTime?
  uninstalledAt         DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  myshopifyDomain          String?  @unique
  primaryDomain            String?
  shopName                 String?
  accessTokenEncrypted     String?
  storefrontTokenEncrypted String?
  appProxyPrefix           String?
  appProxySubpath          String?
  appProxyEnabled          Boolean  @default(false)
  installationStatus       String   @default("DEV")
  checkoutEnabled          Boolean  @default(false)
  tokenExpiresAt           DateTime?
  tokenRotationRequiredAt  DateTime?

  customers             CustomerProfile[]
  otpChallenges         OTPChallenge[]
  orderActionRequests   OrderActionRequest[]
 megaskaOrders         MegaskaOrder[]
  walletReservations    WalletReservation[]
  gstSettings           GstSettings[]
  gstProductTaxMaps     GstProductTaxMap[]
  gstSkuTaxMaps         GstSkuTaxMap[]
  gstOrderImports       GstOrderImport[]
  refundRequests        RefundRequest[]
  codAdvanceSettings    CodAdvanceSettings[]
  codAdvanceIntents     CodAdvanceIntent[]
  moduleConfigs         ShopModuleConfig[]
  proxyRoutes           ShopProxyRoute[]
  installationEvents    ShopInstallationEvent[]
  recoveryTokens        CheckoutRecoveryToken[]
}
model AuthSession {
  id                  String   @id @default(uuid())
  customerProfileId   String
  sessionTokenHash    String   @unique
  expiresAt           DateTime
  revokedAt           DateTime?
  lastSeenAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            CustomerProfile @relation(fields: [customerProfileId], references: [id])
}

 model OTPChallenge {
  id                String   @id @default(uuid())
  shopId            String
  phoneE164         String
  provider          String   // twilio, msg91, mock
  providerSid       String?
  status            String   // pending, verified, failed, expired
  attemptsCount     Int      @default(0)
  requestedAt       DateTime @default(now())
  verifiedAt        DateTime?
  expiresAt         DateTime
  metadata          Json?
  createdAt         DateTime @default(now())

  customerProfileId String?
  customer          CustomerProfile? @relation(fields: [customerProfileId], references: [id])
  shop              Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([shopId, phoneE164])
  @@index([shopId, phoneE164, status, createdAt])
}
model AuditEvent {
  id            String   @id @default(uuid())
  actorType     String   // customer, system, admin
  actorId       String?
  eventType     String
  entityType    String
  entityId      String?
  payload       Json?
  createdAt     DateTime @default(now())
}

enum RequestType {
  EXCHANGE
  REFUND
  CANCELLATION
  ISSUE
}

enum ExchangeRequestStatus {
  OPEN
  AWAITING_PAYMENT
  PAYMENT_RECEIVED
  PICKUP_PENDING
  PICKUP_SCHEDULED
  PICKUP_COMPLETED
  ITEM_RECEIVED
  APPROVED
  REJECTED
  REPLACEMENT_PROCESSING
  REPLACEMENT_SHIPPED
  CLOSED
}

enum PaymentPurpose {
  REVERSE_PICKUP_FEE
}

enum PaymentProvider {
  RAZORPAY
}

enum PaymentStatus {
  NOT_CREATED
  PENDING
  PAID
  FAILED
  EXPIRED
  CANCELLED
}

enum CodAdvanceStatus {
  CREATED
  PAYMENT_PENDING
  ADVANCE_PAID
  ORDER_LINKED
  FAILED
  EXPIRED
  CANCELLED
}

enum RefundSource {
  ORDER_ACTION_REQUEST
  SHOPIFY_REFUND
  ISSUE_REQUEST
  CANCELLATION_REQUEST
  RTO_EVENT
  ADMIN_EXCEPTION
  ORDER_ADJUSTMENT
}

enum RefundMethod {
  COD
  PREPAID
  NO_REFUND
}

enum RefundStatus {
  PENDING
  MANUAL_PENDING
  NOT_REQUIRED
  DETAILS_PENDING
  DETAILS_SUBMITTED
  REVIEW_PENDING
  APPROVED
  REJECTED
  PAYOUT_PENDING
  PAID
  FAILED
  CANCELLED
}

enum RefundPayoutRail {
  UPI
  BANK_TRANSFER
}

enum RefundPayoutStatus {
  CREATED
  IN_PROGRESS
  SUCCESS
  FAILED
  CANCELLED
}

enum RefundActorType {
  SYSTEM
  ADMIN
  CUSTOMER
}


enum ExchangePaymentInvoiceStatus {
  GENERATED
  SENT
  CANCELLED
}

enum ShipmentDirection {
  REVERSE_PICKUP
  FORWARD_REPLACEMENT
}

enum ShipmentStatus {
  NOT_STARTED
  PENDING
  SCHEDULED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model OrderActionRequest {
  id                    String                @id @default(uuid())
  shopId                String?
  requestType           RequestType           @default(EXCHANGE)
  customerProfileId     String
  shopifyCustomerId     String?
  shopifyOrderId        String?
  orderNumber           String
  status                ExchangeRequestStatus @default(OPEN)
  reason                String?
  customerNote          String?
  adminNote             String?
  requestedAt           DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  customerNameSnapshot  String?
  customerPhoneSnapshot String?
  customerEmailSnapshot String?
  orderAmountSnapshot   String?
  deliveryDateSnapshot  DateTime?
  eligibilityDecision   String?
  eligibilityReason     String?
  megaskaOrderId        String?

  customerProfile       CustomerProfile       @relation(fields: [customerProfileId], references: [id])
  shop                  Shop?                 @relation(fields: [shopId], references: [id], onDelete: SetNull)
  items                 OrderActionItem[]
  payments              RequestPayment[]
  invoices              ExchangePaymentInvoice[]
  shipments             ShipmentTracking[]
  refundRequests        RefundRequest[]
  megaskaOrder          MegaskaOrder?         @relation(fields: [megaskaOrderId], references: [id], onDelete: SetNull)

  @@index([customerProfileId])
  @@index([status])
  @@index([orderNumber])
  @@index([shopId])
  @@index([megaskaOrderId])
}

model OrderActionItem {
  id                 String             @id @default(uuid())
  requestId          String
  shopifyLineItemId  String?
  productTitle       String
  variantTitle       String?
  sku                String?
  currentSize        String?
  requestedSize      String
  quantity           Int                @default(1)
  isClearance        Boolean            @default(false)
  isExcludedCategory Boolean            @default(false)
  eligibilitySnapshot Json?
  createdAt          DateTime           @default(now())

  request            OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model RequestPayment {
  id                  String         @id @default(uuid())
  requestId           String
  purpose             PaymentPurpose @default(REVERSE_PICKUP_FEE)
  provider            PaymentProvider @default(RAZORPAY)
  amount              Int
  currency            String         @default("INR")
  status              PaymentStatus  @default(NOT_CREATED)
  paymentLinkId       String?
  paymentLinkUrl      String?
  providerReferenceId String?
  paymentId           String?
  paidAt              DateTime?
  expiresAt           DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  request             OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  invoice             ExchangePaymentInvoice?

  @@index([requestId])
  @@index([status])
  @@index([paymentLinkId])
}

model CodAdvanceSettings {
  id                        String   @id @default(uuid())
  shopId                    String
  enabled                   Boolean  @default(false)
  fixedAdvanceAmountPaise   Int      @default(12000)
  currency                  String   @default("INR")
  minOrderAmountPaise       Int?
  maxOrderAmountPaise       Int?
  policyText                String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  shop                      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model CodAdvanceIntent {
  id                         String           @id @default(uuid())
  shopId                     String
  customerProfileId          String?
  cartReference              String?
  checkoutReference          String?
  shopifyOrderId             String?
  shopifyOrderName           String?
  orderAmountPaise           Int
  advanceAmountPaise         Int
  codBalanceAmountPaise      Int
  currency                   String           @default("INR")
  status                     CodAdvanceStatus @default(CREATED)
  razorpayPaymentLinkId      String?
  razorpayPaymentLinkUrl     String?
  razorpayPaymentId          String?
  providerReferenceId        String?
  paidAt                     DateTime?
  expiresAt                  DateTime?
  metadata                   Json?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  shop                       Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerProfile            CustomerProfile? @relation(fields: [customerProfileId], references: [id])

  @@index([shopId])
  @@index([status])
  @@index([razorpayPaymentLinkId])
  @@index([shopifyOrderId])
  @@index([customerProfileId, createdAt])
}

model ShipmentTracking {
  id          String            @id @default(uuid())
  requestId   String
  direction   ShipmentDirection
  carrier     String?
  awb         String?
  trackingUrl String?
  status      ShipmentStatus    @default(NOT_STARTED)
  pickupAt    DateTime?
  shippedAt   DateTime?
  deliveredAt DateTime?
  remarks     String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  request     OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@unique([requestId, direction])
}


enum MegaskaOrderStatus {
  ORDER_CONFIRMED
  PROCESSING
  PACKED
  READY_FOR_PICKUP
  PICKED_UP
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELIVERY_FAILED
  RTO_INITIATED
  RTO_DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURN_IN_TRANSIT
  REFUNDED
}

enum CourierProvider {
  DELHIVERY
  DTDC
  ATS
  OTHER
}


model MegaskaOrder {
  id                 String             @id @default(uuid())
  shopId             String
  customerProfileId  String
  shopifyOrderId     String?
  shopifyOrderName   String
  orderPlacedAt      DateTime?
  status             MegaskaOrderStatus @default(ORDER_CONFIRMED)
  statusSource       String?
  statusUpdatedAt    DateTime?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  shop               Shop               @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerProfile    CustomerProfile    @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  shipments          OrderShipment[]
  actionRequests     OrderActionRequest[]

  @@unique([shopId, shopifyOrderName])
  @@index([customerProfileId, createdAt])
  @@index([shopifyOrderId])
  @@index([status])
}

model OrderShipment {
  id                 String             @id @default(uuid())
  orderId            String
  provider           CourierProvider    @default(OTHER)
  providerReference  String?
  awb                String?
  trackingUrl        String?
  normalizedStatus   MegaskaOrderStatus @default(ORDER_CONFIRMED)
  statusUpdatedAt    DateTime?
  rawStatus          String?
  metadata           Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  order              MegaskaOrder       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  events             OrderShipmentEvent[]

  @@index([orderId, createdAt])
  @@index([provider, providerReference])
  @@index([awb])
}

model OrderShipmentEvent {
  id                 String             @id @default(uuid())
  shipmentId         String
  occurredAt         DateTime
  normalizedStatus   MegaskaOrderStatus
  rawStatus          String?
  description        String?
  location           String?
  metadata           Json?
  createdAt          DateTime           @default(now())

  shipment           OrderShipment      @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([shipmentId, occurredAt])
}

enum WalletDirection {
  CREDIT
  DEBIT
}

enum WalletTransactionType {
  COD_REFUND_CREDIT
  MANUAL_CREDIT
  MANUAL_DEBIT
  ADJUSTMENT
  GOODWILL_CREDIT
  CHECKOUT_REDEMPTION
}

enum WalletSourceType {
  ISSUE_REQUEST
  ADMIN_MANUAL
  WALLET_RESERVATION
}

enum WalletActorType {
  SYSTEM
  ADMIN
}

model WalletAccount {
  id                String   @id @default(uuid())
  customerProfileId String
  currency          String   @default("INR")
  currentBalance    Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  customer          CustomerProfile     @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  transactions      WalletTransaction[]
  reservations      WalletReservation[]

  @@unique([customerProfileId, currency])
  @@index([customerProfileId])
}

model WalletTransaction {
  id                  String                @id @default(uuid())
  walletAccountId     String
  customerProfileId   String
  direction           WalletDirection
  transactionType     WalletTransactionType
  amount              Int
  currency            String                @default("INR")
  sourceType          WalletSourceType
  sourceId            String?
  sourceReference     String?
  orderNumber         String?
  reason              String?
  adminNote           String?
  createdByType       WalletActorType
  createdById         String?
  createdAt           DateTime              @default(now())

  walletAccount       WalletAccount         @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  customer            CustomerProfile       @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([customerProfileId, createdAt])
  @@index([walletAccountId, createdAt])
  @@index([sourceType, sourceId])
  @@unique([sourceType, sourceId, transactionType])
}


enum WalletReservationStatus {
  ACTIVE
  CONSUMED
  RELEASED
  EXPIRED
}

enum WalletReservationSourceFlow {
  CHECKOUT
  BUY_NOW
}

model WalletReservation {
  id                String                      @id @default(uuid())
  shopId            String?
  walletAccountId   String
  customerProfileId String
  reservedAmount    Int
  currency          String                      @default("INR")
  status            WalletReservationStatus     @default(ACTIVE)
  discountCode      String?
  shopifyDiscountId String?
  sourceFlow        WalletReservationSourceFlow @default(CHECKOUT)
  cartReference     String?
  checkoutReference String?
  sessionReference  String?
  orderNumber       String?
  shopifyOrderId    String?
  releaseReason     String?
  expiresAt         DateTime
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @updatedAt

  walletAccount     WalletAccount               @relation(fields: [walletAccountId], references: [id], onDelete: Cascade)
  customer          CustomerProfile             @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  shop              Shop?                       @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([customerProfileId, status, expiresAt])
  @@index([walletAccountId, status, expiresAt])
  @@index([discountCode])
  @@index([shopifyOrderId])
  @@index([shopId, status, expiresAt])
}

model RefundRequest {
  id                      String          @id @default(uuid())
  shopId                  String
  source                  RefundSource
  sourceId                String
  method                  RefundMethod    @default(COD)
  status                  RefundStatus    @default(DETAILS_PENDING)
  currency                String          @default("INR")
  amount                  Int
  customerProfileId       String?
  orderActionRequestId    String?
  shopifyOrderId          String?
  shopifyRefundId         String?
  reason                  String?
  customerNote            String?
  adminNote               String?
  metadata                Json?
  detailsSubmittedAt      DateTime?
  approvedAt              DateTime?
  rejectedAt              DateTime?
  paidAt                  DateTime?
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  shop                    Shop            @relation(fields: [shopId], references: [id], onDelete: Cascade)
  customerProfile         CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  orderActionRequest      OrderActionRequest? @relation(fields: [orderActionRequestId], references: [id], onDelete: SetNull)
  payoutDetails           RefundPayoutDetails?
  payouts                 RefundPayout[]
  events                  RefundEvent[]

  @@unique([shopId, source, sourceId])
  @@index([shopId, status, createdAt])
  @@index([customerProfileId, createdAt])
  @@index([orderActionRequestId])
}

model RefundPayoutDetails {
  id                      String           @id @default(uuid())
  refundRequestId         String           @unique
  rail                    RefundPayoutRail
  accountHolderName       String?
  bankAccountMasked       String?
  bankAccountEnc          String?
  bankIfsc                String?
  upiIdMasked             String?
  upiIdEnc                String?
  phoneMasked             String?
  phoneEnc                String?
  verifiedAt              DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  refundRequest           RefundRequest    @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)
}

model RefundPayout {
  id                      String            @id @default(uuid())
  refundRequestId         String
  status                  RefundPayoutStatus @default(CREATED)
  provider                String?           // manual, razorpay, etc.
  providerReferenceId     String?
  amount                  Int
  currency                String            @default("INR")
  initiatedAt             DateTime?
  completedAt             DateTime?
  failureReason           String?
  metadata                Json?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  refundRequest           RefundRequest     @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)

  @@index([refundRequestId, createdAt])
  @@index([status, createdAt])
}

model RefundEvent {
  id                      String          @id @default(uuid())
  refundRequestId         String
  actorType               RefundActorType
  actorId                 String?
  eventType               String
  fromStatus              RefundStatus?
  toStatus                RefundStatus?
  message                 String?
  payload                 Json?
  createdAt               DateTime        @default(now())

  refundRequest           RefundRequest   @relation(fields: [refundRequestId], references: [id], onDelete: Cascade)

  @@index([refundRequestId, createdAt])
}


enum GstDocumentType {
  TAX_INVOICE
  CREDIT_NOTE
  DEBIT_NOTE
}

enum GstDocumentStatus {
  DRAFT
  ISSUED
  CANCELLED
  VOID
  FAILED
}

enum GstNumberingStrategy {
  FINANCIAL_YEAR_SEQUENCE
  CALENDAR_YEAR_SEQUENCE
  MONTHLY_SEQUENCE
  MANUAL
}

enum GstSupplyType {
  B2B
  B2C
  EXPORT
  SEZ_WITH_PAYMENT
  SEZ_WITHOUT_PAYMENT
  DEEMED_EXPORT
}

model GstSettings {
  id                    String   @id @default(uuid())
  shopId                String?
  legalName             String
  tradeName             String?
  gstin                 String   @unique
  pan                   String?
  stateCode             String
  invoicePrefix         String
  creditNotePrefix      String
  debitNotePrefix       String
  invoiceNumberStrategy GstNumberingStrategy
  defaultCurrency       String   @default("INR")
  priceIncludesTax      Boolean  @default(true)
  einvoiceEnabled       Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  documents             GstDocument[]
  counters              GstCounter[]
  exports               GstExport[]
  reconciliationRuns    GstReconciliationRun[]
  auditLogs             GstAuditLog[]
  orderImports          GstOrderImport[]
  invoiceTemplates      GstInvoiceTemplate[]
  reportRuns            GstReportRun[]
  shop                  Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId])
}

model GstCounter {
  id            String      @id @default(uuid())
  gstSettingsId String
  documentType  GstDocumentType
  financialYear String
  lastNumber    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  gstSettings   GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)

  @@unique([gstSettingsId, documentType, financialYear])
  @@index([gstSettingsId, documentType])
}

model GstDocument {
  id                     String            @id @default(uuid())
  documentType           GstDocumentType
  status                 GstDocumentStatus
  documentNumber         String            @unique
  documentDate           DateTime
  gstSettingsId          String
  gstSettings            GstSettings       @relation(fields: [gstSettingsId], references: [id])

  shopifyOrderId         String?
  shopifyOrderName       String?
  sourceOrderId          String?
  sourceOrderNumber      String?
  sourceReference        String?
  customerProfileId      String?
  customer               CustomerProfile?  @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  originalDocumentId     String?
  originalDocument       GstDocument?      @relation("GstDocToOriginal", fields: [originalDocumentId], references: [id])
  derivedNotes           GstDocument[]     @relation("GstDocToOriginal")

  supplyType             GstSupplyType
  placeOfSupplyStateCode String
  isInterstate           Boolean
  currency               String            @default("INR")

  taxableAmount          Decimal           @db.Decimal(14, 2)
  cgstAmount             Decimal           @db.Decimal(14, 2)
  sgstAmount             Decimal           @db.Decimal(14, 2)
  igstAmount             Decimal           @db.Decimal(14, 2)
  cessAmount             Decimal           @db.Decimal(14, 2)
  totalAmount            Decimal           @db.Decimal(14, 2)

  pdfFileUrl             String?
  jsonSnapshot           Json
  metadata               Json?
  issuedAt               DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  lines                  GstDocumentLine[]
  exportItems            GstExportItem[]
  auditLogs              GstAuditLog[]
  legacyLinks            GstLegacyDocument[]

  @@index([gstSettingsId])
  @@index([customerProfileId])
  @@index([sourceOrderId])
  @@index([sourceOrderNumber])
  @@index([originalDocumentId])
  @@index([status, documentDate])
}

model GstDocumentLine {
  id            String      @id @default(uuid())
  gstDocumentId String
  lineNumber    Int
  description   String
  hsnOrSac      String?
  quantity      Decimal     @db.Decimal(14, 3)
  unit          String?
  unitPrice     Decimal     @db.Decimal(14, 2)
  discount      Decimal     @db.Decimal(14, 2) @default(0)
  taxableAmount Decimal     @db.Decimal(14, 2)
  taxRate       Decimal     @db.Decimal(5, 2)
  cgstAmount    Decimal     @db.Decimal(14, 2)
  sgstAmount    Decimal     @db.Decimal(14, 2)
  igstAmount    Decimal     @db.Decimal(14, 2)
  cessAmount    Decimal     @db.Decimal(14, 2)
  lineTotal     Decimal     @db.Decimal(14, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  document      GstDocument @relation(fields: [gstDocumentId], references: [id], onDelete: Cascade)

  @@unique([gstDocumentId, lineNumber])
  @@index([gstDocumentId])
}


model GstParty {
  id                  String   @id @default(uuid())
  gstin               String?  @unique
  legalName           String
  tradeName           String?
  customerProfileId   String?
  email               String?
  phone               String?
  stateCode           String?
  countryCode         String   @default("IN")
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  customer            CustomerProfile? @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)
  auditLogs           GstAuditLog[]
  legacyDocuments     GstLegacyDocument[]

  @@index([customerProfileId])
  @@index([legalName])
}

model GstExport {
  id                  String   @id @default(uuid())
  gstSettingsId       String
  exportType          String
  periodStart         DateTime
  periodEnd           DateTime
  status              String
  storageUrl          String?
  checksum            String?
  filters             Json?
  generatedByType     String?
  generatedById       String?
  generatedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstSettings         GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)
  items               GstExportItem[]
  auditLogs           GstAuditLog[]

  @@index([gstSettingsId, periodStart, periodEnd])
  @@index([status, createdAt])
  @@unique([gstSettingsId, exportType, periodStart, periodEnd])
}

model GstExportItem {
  id                  String   @id @default(uuid())
  gstExportId         String
  gstDocumentId       String?
  rowNumber           Int
  documentType        GstDocumentType?
  documentNumber      String?
  documentDate        DateTime?
  status              String
  payload             Json
  errorCode           String?
  errorMessage        String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstExport           GstExport    @relation(fields: [gstExportId], references: [id], onDelete: Cascade)
  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)

  @@unique([gstExportId, rowNumber])
  @@index([gstDocumentId])
  @@index([status])
  @@index([documentType, documentDate])
}

model GstReconciliationRun {
  id                  String   @id @default(uuid())
  gstSettingsId       String
  periodStart         DateTime
  periodEnd           DateTime
  sourceSystem        String
  status              String
  matchedCount        Int      @default(0)
  mismatchedCount     Int      @default(0)
  missingInBooksCount Int      @default(0)
  missingInPortalCount Int     @default(0)
  summary             Json?
  startedAt           DateTime @default(now())
  completedAt         DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstSettings         GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)
  auditLogs           GstAuditLog[]

  @@index([gstSettingsId, periodStart, periodEnd])
  @@index([status, startedAt])
}

model GstAuditLog {
  id                  String   @id @default(uuid())
  gstSettingsId       String?
  gstDocumentId       String?
  gstPartyId          String?
  gstExportId         String?
  reconciliationRunId String?
  action              String
  actorType           String
  actorId             String?
  previousState       Json?
  nextState           Json?
  metadata            Json?
  createdAt           DateTime @default(now())

  gstSettings         GstSettings? @relation(fields: [gstSettingsId], references: [id], onDelete: SetNull)
  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)
  gstParty            GstParty?    @relation(fields: [gstPartyId], references: [id], onDelete: SetNull)
  gstExport           GstExport?   @relation(fields: [gstExportId], references: [id], onDelete: SetNull)
  reconciliationRun   GstReconciliationRun? @relation(fields: [reconciliationRunId], references: [id], onDelete: SetNull)

  @@index([gstDocumentId, createdAt])
  @@index([gstPartyId, createdAt])
  @@index([gstExportId, createdAt])
  @@index([reconciliationRunId, createdAt])
  @@index([action, createdAt])
}

model GstLegacyDocument {
  id                  String   @id @default(uuid())
  sourceSystem        String
  legacyDocumentId    String
  legacyDocumentNumber String?
  documentType        GstDocumentType?
  documentStatus      GstDocumentStatus?
  gstDocumentId       String?
  gstPartyId          String?
  payload             Json?
  importedAt          DateTime @default(now())
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  gstDocument         GstDocument? @relation(fields: [gstDocumentId], references: [id], onDelete: SetNull)
  gstParty            GstParty?    @relation(fields: [gstPartyId], references: [id], onDelete: SetNull)

  @@unique([sourceSystem, legacyDocumentId])
  @@index([legacyDocumentNumber])
  @@index([gstDocumentId])
  @@index([gstPartyId])
}

model GstHsnCode {
  id            String          @id @default(uuid())
  hsnCode       String          @unique
  description   String
  isService     Boolean         @default(false)
  isActive      Boolean
  effectiveFrom DateTime?       @db.Date
  effectiveTo   DateTime?       @db.Date
  metadata      Json?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  slabMaps      GstHsnSlabMap[]
  productMaps   GstProductTaxMap[]
}

model GstTaxSlab {
  id            String          @id @default(uuid())
  slabCode      String          @unique
  taxRate       Decimal         @db.Decimal(5, 2)
  cessRate      Decimal         @default(0) @db.Decimal(5, 2)
  isActive      Boolean
  effectiveFrom DateTime?       @db.Date
  effectiveTo   DateTime?       @db.Date
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  hsnMaps       GstHsnSlabMap[]
  productMaps   GstProductTaxMap[]
}

model GstHsnSlabMap {
  id            String      @id @default(uuid())
  hsnId         String
  slabId        String
  effectiveFrom DateTime?   @db.Date
  effectiveTo   DateTime?   @db.Date
  priority      Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  hsn           GstHsnCode  @relation(fields: [hsnId], references: [id], onDelete: Cascade)
  slab          GstTaxSlab  @relation(fields: [slabId], references: [id], onDelete: Cascade)

  @@index([hsnId])
  @@index([slabId])
  @@index([effectiveFrom, effectiveTo])
  @@unique([hsnId, slabId, effectiveFrom, effectiveTo])
}

model GstProductTaxMap {
  id               String      @id @default(uuid())
  shopId            String?
  shopifyProductId String
  shopifyVariantId String?
  hsnId            String
  slabId           String
  source           String
  status           String
  effectiveFrom    DateTime?   @db.Date
  effectiveTo      DateTime?   @db.Date
  lastValidatedAt  DateTime?
  metadata         Json?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  hsn              GstHsnCode  @relation(fields: [hsnId], references: [id], onDelete: Restrict)
  slab             GstTaxSlab  @relation(fields: [slabId], references: [id], onDelete: Restrict)
  shop             Shop?       @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId])
  @@index([shopifyProductId])
  @@index([shopifyVariantId])
  @@index([status])
  @@unique([shopId, shopifyProductId, shopifyVariantId])
}

model GstSkuTaxMap {
  id         String   @id @default(uuid())
  shopId     String?
  sku        String?
  styleCode  String?
  hsnCode    String
  taxRate    Decimal  @db.Decimal(5, 2)
  cessRate   Decimal  @default(0) @db.Decimal(5, 2)
  source     String   @default("BULK_CSV")
  status     String   @default("ACTIVE")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop       Shop?    @relation(fields: [shopId], references: [id], onDelete: SetNull)

  @@index([shopId, sku])
  @@index([shopId, styleCode])
  @@index([status])
}

model GstOrderImport {
  id               String               @id @default(uuid())
  shopId            String?
  gstSettingsId    String
  shopifyOrderId   String
  shopifyOrderName String
  orderCreatedAt   DateTime
  orderCurrency    String
  orderSubtotal    Decimal              @db.Decimal(14, 2)
  orderTaxTotal    Decimal              @db.Decimal(14, 2)
  orderGrandTotal  Decimal              @db.Decimal(14, 2)
  shippingStateCode String?
  billingStateCode String?
  importStatus     String
  eligibilityStatus String
  readinessErrors  Json                 @default("[]")
  snapshot         Json
  lastSyncedAt     DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  gstSettings      GstSettings          @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)
  shop             Shop?                @relation(fields: [shopId], references: [id], onDelete: SetNull)
  lines            GstOrderImportLine[]

  @@index([shopId])
  @@index([gstSettingsId])
  @@index([shopifyOrderName])
  @@index([importStatus, eligibilityStatus])
  @@index([orderCreatedAt])
  @@unique([shopId, shopifyOrderId])
}

model GstOrderImportLine {
  id               String        @id @default(uuid())
  gstOrderImportId String
  lineNumber       Int
  shopifyLineItemId String?
  shopifyProductId String?
  shopifyVariantId String?
  title            String
  sku              String?
  quantity         Decimal       @db.Decimal(14, 3)
  unitPrice        Decimal       @db.Decimal(14, 2)
  discount         Decimal       @db.Decimal(14, 2) @default(0)
  taxableAmount    Decimal       @db.Decimal(14, 2)
  mappedHsnCode    String?
  mappedTaxRate    Decimal?      @db.Decimal(5, 2)
  mappedCessRate   Decimal?      @db.Decimal(5, 2)
  mappingStatus    String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  orderImport      GstOrderImport @relation(fields: [gstOrderImportId], references: [id], onDelete: Cascade)

  @@unique([gstOrderImportId, lineNumber])
  @@index([gstOrderImportId])
  @@index([shopifyProductId])
  @@index([shopifyVariantId])
  @@index([mappingStatus])
}

model GstInvoiceTemplate {
  id               String      @id @default(uuid())
  gstSettingsId    String
  templateName     String
  isActive         Boolean
  isDefault        Boolean
  headerText       String?
  footerText       String?
  declarationText  String?
  notesText        String?
  logoFileUrl      String?
  themeConfig      Json?
  version          Int
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  gstSettings      GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)

  @@index([gstSettingsId, isActive])
  @@index([gstSettingsId, isDefault])
}

model GstReportRun {
  id            String      @id @default(uuid())
  gstSettingsId String
  reportType    String
  periodStart   DateTime
  periodEnd     DateTime
  format        String
  status        String
  filters       Json?
  fileUrl       String?
  checksum      String?
  rowCount      Int
  generatedAt   DateTime?
  errorMessage  String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  gstSettings   GstSettings @relation(fields: [gstSettingsId], references: [id], onDelete: Cascade)

  @@index([gstSettingsId, reportType, periodStart, periodEnd])
  @@index([status, createdAt])
}


model ExchangePaymentInvoice {
  id                 String @id @default(uuid())
  requestPaymentId   String @unique
  requestId          String
  invoiceNumber      String @unique
  invoiceDate        DateTime
  invoiceStatus      ExchangePaymentInvoiceStatus @default(GENERATED)
  customerName       String
  customerPhone      String?
  customerEmail      String?
  orderNumber        String
  description        String
  amountPaise        Int
  taxableAmountPaise Int
  gstRatePercent     Float
  cgstPaise          Int @default(0)
  sgstPaise          Int @default(0)
  igstPaise          Int @default(0)
  totalPaise         Int
  currency           String @default("INR")
  pdfUrl             String?
  htmlSnapshot       String?
  textSnapshot       String?
  sentAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  requestPayment     RequestPayment @relation(fields: [requestPaymentId], references: [id], onDelete: Cascade)
  request            OrderActionRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

enum ExpressCheckoutIntentStatus {
  CREATED
  CUSTOMER_AUTHENTICATED
  CART_SNAPSHOT_LOCKED
  ADDRESS_CAPTURED
  DISCOUNT_APPLIED
  PAYMENT_METHOD_SELECTED
  PAYMENT_PENDING
  PAYMENT_CONFIRMED
  ORDER_CREATING
  ORDER_CREATED
  FAILED
  EXPIRED
  CANCELLED
  INITIATED
  SESSION_VERIFIED
  ADDRESS_COMPLETED
  DELIVERY_VALIDATED
  COUPON_APPLIED
  PAYMENT_SELECTED
  DRAFT_ORDER_CREATED
  PAYMENT_SUCCESS
  ORDER_COMPLETED
  PAYMENT_FAILED
  PAYMENT_CANCELLED
  ABANDONED
}

enum ExpressCheckoutPaymentMethod {
  PREPAID
  COD
}

enum ExpressCheckoutPaymentStatus {
  NOT_REQUIRED
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

enum ExpressCheckoutDiscountType {
  MANUAL_CODE
  AUTOMATIC
}

enum CheckoutRecoveryType {
  CHECKOUT_ABANDONMENT
  PAYMENT_ABANDONMENT
}

enum CheckoutRecoveryTokenStatus {
  ACTIVE
  USED
  EXPIRED
  REVOKED
}

model ExpressCheckoutIntent {
  id                    String                       @id @default(uuid())
  shopId                String
  customerProfileId     String?
  sessionTokenHash      String?
  status                ExpressCheckoutIntentStatus @default(CREATED)
  phoneSnapshot         String?
  cartToken             String?
  shopifyCartId         String?
  cartSnapshot          Json?
  subtotalAmountPaise   Int                         @default(0)
  discountAmountPaise   Int                         @default(0)
  shippingAmountPaise   Int                         @default(0)
  codFeeAmountPaise     Int                         @default(0)
  totalAmountPaise      Int                         @default(0)
  currency              String                      @default("INR")
  selectedPaymentMethod ExpressCheckoutPaymentMethod?
  expiresAt             DateTime?
  createdAt             DateTime                    @default(now())
  updatedAt             DateTime                    @updatedAt

  addressSnapshots      ExpressCheckoutAddressSnapshot[]
  discounts             ExpressCheckoutDiscount[]
  payments              ExpressCheckoutPayment[]
  orderLink             ExpressCheckoutOrderLink?
  recoveryTokens        CheckoutRecoveryToken[]

  @@index([shopId, id])
  @@index([shopId, customerProfileId])
  @@index([shopId, status])
  @@index([shopId, sessionTokenHash])
  @@index([shopId, cartToken])
  @@index([shopId, shopifyCartId])
}

model CheckoutRecoveryToken {
  id                 String                      @id @default(uuid())
  shopId             String
  checkoutIntentId   String
  customerProfileId  String?
  tokenHash          String                      @unique
  recoveryType       CheckoutRecoveryType
  status             CheckoutRecoveryTokenStatus @default(ACTIVE)
  expiresAt          DateTime
  clickedAt          DateTime?
  usedAt             DateTime?
  revokedAt          DateTime?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  metadata           Json?

  shop               Shop                        @relation(fields: [shopId], references: [id], onDelete: Cascade)
  checkoutIntent     ExpressCheckoutIntent       @relation(fields: [checkoutIntentId], references: [id], onDelete: Cascade)
  customerProfile    CustomerProfile?            @relation(fields: [customerProfileId], references: [id], onDelete: SetNull)

  @@index([shopId, tokenHash, status])
  @@index([shopId, checkoutIntentId])
}

model ExpressCheckoutAddressSnapshot {
  id                String                @id @default(uuid())
  shopId            String
  intentId          String
  customerProfileId String?
  name              String
  phone             String
  email             String?
  address1          String
  address2          String?
  city              String
  province          String
  country           String                @default("India")
  zip               String
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  intent            ExpressCheckoutIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
  @@index([shopId, intentId])
  @@index([shopId, customerProfileId])
}

model ExpressCheckoutDiscount {
  id                  String                      @id @default(uuid())
  shopId              String
  intentId            String
  type                ExpressCheckoutDiscountType
  code                String?
  title               String?
  discountAmountPaise Int                         @default(0)
  rawShopifyPayload   Json?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  intent              ExpressCheckoutIntent       @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
  @@index([shopId, intentId])
  @@index([shopId, code])
}

model ExpressCheckoutPayment {
  id                    String                       @id @default(uuid())
  shopId                String
  intentId              String
  method                ExpressCheckoutPaymentMethod
  status                ExpressCheckoutPaymentStatus @default(PENDING)
  amountPaise           Int                          @default(0)
  currency              String                       @default("INR")
  razorpayOrderId       String?
  razorpayPaymentId     String?
  razorpaySignatureHash String?
  failureReason         String?
  rawGatewayPayload     Json?
  createdAt             DateTime                     @default(now())
  updatedAt             DateTime                     @updatedAt

  intent                ExpressCheckoutIntent        @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@index([shopId, id])
  @@index([shopId, intentId])
  @@index([shopId, status])
  @@unique([shopId, razorpayOrderId])
  @@unique([shopId, razorpayPaymentId])
}

model ExpressCheckoutOrderLink {
  id                String                @id @default(uuid())
  shopId            String
  intentId          String                @unique
  draftOrderId      String?
  draftOrderName    String?
  shopifyOrderId    String?
  shopifyOrderName  String?
  financialStatus   String?
  fulfillmentStatus String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  intent            ExpressCheckoutIntent @relation(fields: [intentId], references: [id], onDelete: Cascade)

  @@unique([shopId, intentId])
  @@index([shopId, id])
  @@index([shopId, intentId])
  @@index([shopId, shopifyOrderId])
}

model ShopModuleConfig {
  id        String   @id @default(uuid())
  shopId    String
  moduleKey String
  enabled   Boolean  @default(false)
  config    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, moduleKey])
  @@index([shopId])
  @@index([moduleKey, enabled])
}

model ShopProxyRoute {
  id           String   @id @default(uuid())
  shopId       String
  routeKey     String
  proxyPrefix  String
  proxySubpath String
  targetModule String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop         Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@unique([shopId, routeKey])
  @@index([shopId, isActive])
  @@index([targetModule, isActive])
}

model ShopInstallationEvent {
  id        String   @id @default(uuid())
  shopId    String
  eventType String
  scopes    String?
  payload   Json?
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId, createdAt])
  @@index([eventType, createdAt])
}
